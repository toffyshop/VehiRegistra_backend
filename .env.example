# Copiar como .env y ajustar valores.

ENVIRONMENT=dev
PROJECT_NAME=VehiRegistro API

# Generar con: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=cambiame-por-una-clave-larga-y-aleatoria
ACCESS_TOKEN_EXPIRE_MINUTES=480

# SQLite (desarrollo)
DATABASE_URL=sqlite+aiosqlite:///./vehiregistro.db
# PostgreSQL (produccion)
# DATABASE_URL=postgresql+asyncpg://usuario:password@localhost:5432/vehiregistro

SQL_ECHO=false

# Orígenes permitidos, separados por coma. "*" para desarrollo con emulador Android.
BACKEND_CORS_ORIGINS=*

# Archivos subidos (fotografías de vehículos)
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5
# URL base pública usada para construir photo_url absoluta
PUBLIC_BASE_URL=http://localhost:8000

# Crea tablas y datos de ejemplo al arrancar (desactivar en producción)
SEED_ON_STARTUP=true

# --- Consulta vehicular externa (SUNARP) ---
# Sin SUNARP_API_TOKEN el servicio responde con datos simulados.
SUNARP_API_URL=https://api2.consultadatos.com/api/placa/leyenda
SUNARP_API_TOKEN=
SUNARP_TIMEOUT_SECONDS=10
# Si el proveedor falla, responder con el mock en vez de un error.
SUNARP_FALLBACK_TO_MOCK=true
